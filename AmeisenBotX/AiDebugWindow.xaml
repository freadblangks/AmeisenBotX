<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="AmeisenBotX.AiDebugWindow"
        Title="AI Visualization" Height="600" Width="1000" WindowStyle="None" AllowsTransparency="True" BorderThickness="1" ResizeMode="CanResizeWithGrip" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.BorderBrush>
        <SolidColorBrush Color="{DynamicResource DarkAccent1}" />
    </Window.BorderBrush>
    <Window.Background>
        <SolidColorBrush Color="{DynamicResource DarkBackground}" />
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header / Status -->
        <Border Background="#252526" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Strategy: " Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="StrategyText" Text="Unknown" Foreground="#007ACC" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>

                <TextBlock Text="Win Probability: " Foreground="#CCCCCC" FontSize="16"/>
                <TextBlock x:Name="WinProbText" Text="0%" Foreground="LimeGreen" FontSize="16" Margin="0,0,20,0"/>

                <TextBlock Text="Status: " Foreground="#CCCCCC" FontSize="16"/>
                <TextBlock x:Name="StatusText" Text="Waiting..." Foreground="#AAAAAA" FontSize="16"/>
            </StackPanel>
        </Border>

        <!-- Neural Net Canvas -->
        <Canvas x:Name="BrainCanvas" Grid.Row="1" Background="#1E1E1E" ClipToBounds="True"/>

        <!-- Tooltip Overlay -->
        <Popup x:Name="InfoPopup" Placement="Mouse" IsOpen="False">
            <Border Background="#333333" BorderBrush="#007ACC" BorderThickness="1" CornerRadius="4" Padding="5">
                <TextBlock x:Name="PopupText" Foreground="White"/>
            </Border>
        </Popup>
        <Button x:Name="buttonExit" Content="❌" Click="ButtonExit_Click" BorderThickness="1,0,0,0" Padding="1,1,1,3" HorizontalAlignment="Right" Width="28" Height="27" VerticalAlignment="Top" FontFamily="Verdana" Style="{DynamicResource ButtonStyleDark}" FontSize="14">
            <Button.Foreground>
                <SolidColorBrush Color="{DynamicResource DarkForeground}" />
            </Button.Foreground>
        </Button>
    </Grid>
</Window>
