<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ============================================
         AmeisenBotX Unified Theme - Colors
         ============================================ -->
    
    <!-- Primary Background Colors -->
    <Color x:Key="Background">#FF212121</Color>
    <Color x:Key="BackgroundAlt">#FF141414</Color>
    <Color x:Key="BackgroundElevated">#FF2A2A2A</Color>
    <Color x:Key="Surface">#FF1A1A1A</Color>
    
    <!-- Border Colors -->
    <Color x:Key="Border">#FF969696</Color>
    <Color x:Key="BorderSubtle">#FF404040</Color>
    <Color x:Key="BorderMuted">#FF333333</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#FFFFFFFF</Color>
    <Color x:Key="TextSecondary">#FF969696</Color>
    <Color x:Key="TextMutedColor">#FF666666</Color>
    <Color x:Key="TextDisabled">#FF555555</Color>
    
    <!-- Accent Colors -->
    <Color x:Key="Accent">#FFFF6500</Color>
    <Color x:Key="AccentHover">#FFFF7F00</Color>
    <Color x:Key="AccentPressed">#FFCC5200</Color>
    <Color x:Key="AccentMuted">#99FF6500</Color>
    <Color x:Key="AccentGlow">#40FF6500</Color>
    <Color x:Key="AccentSubtle">#1AFF6500</Color>
    
    <!-- Glassmorphism Colors -->
    <Color x:Key="GlassSurface">#CC1A1A1A</Color>
    <Color x:Key="GlassBorder">#40FFFFFF</Color>
    <Color x:Key="GlassHighlight">#10FFFFFF</Color>
    
    <!-- Gradient Colors (derived from existing palette) -->
    <Color x:Key="GradientHealthStart">#FF80FF00</Color>
    <Color x:Key="GradientHealthEnd">#FF40C000</Color>
    <Color x:Key="GradientManaStart">#FF00FFFF</Color>
    <Color x:Key="GradientManaEnd">#FF0080C0</Color>
    <Color x:Key="GradientExpStart">#FFFF8000</Color>
    <Color x:Key="GradientExpEnd">#FFCC5200</Color>
    <Color x:Key="GradientAccentStart">#FFFF7F00</Color>
    <Color x:Key="GradientAccentEnd">#FFFF6500</Color>
    
    <!-- Semantic Colors -->
    <Color x:Key="Success">#FF80FF00</Color>
    <Color x:Key="Warning">#FFFF8000</Color>
    <Color x:Key="Error">#FFFF0050</Color>
    <Color x:Key="Info">#FF00FFFF</Color>
    
    <!-- Game-specific Colors -->
    <Color x:Key="HealthBar">#FF80FF00</Color>
    <Color x:Key="ManaBar">#FF00FFFF</Color>
    <Color x:Key="ExpBar">#FFFF8000</Color>
    <Color x:Key="AllianceBlue">#FF0078FF</Color>
    <Color x:Key="HordeRed">#FFB30000</Color>
    
    <!-- ============================================
         SolidColorBrush Resources (for direct binding)
         ============================================ -->
    
    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="BackgroundAltBrush" Color="{StaticResource BackgroundAlt}"/>
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevated}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    
    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderMutedBrush" Color="{StaticResource BorderMuted}"/>
    
    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}"/>
    
    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressed}"/>
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlow}"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtle}"/>
    
    <!-- Glassmorphism Brushes -->
    <SolidColorBrush x:Key="GlassSurfaceBrush" Color="{StaticResource GlassSurface}"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}"/>
    <SolidColorBrush x:Key="GlassHighlightBrush" Color="{StaticResource GlassHighlight}"/>
    
    <!-- Semantic Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}"/>
    
    <!-- Game Brushes -->
    <SolidColorBrush x:Key="HealthBarBrush" Color="{StaticResource HealthBar}"/>
    <SolidColorBrush x:Key="ManaBarBrush" Color="{StaticResource ManaBar}"/>
    <SolidColorBrush x:Key="ExpBarBrush" Color="{StaticResource ExpBar}"/>
    <SolidColorBrush x:Key="AllianceBrush" Color="{StaticResource AllianceBlue}"/>
    <SolidColorBrush x:Key="HordeBrush" Color="{StaticResource HordeRed}"/>
    
    <!-- Gradient Brushes for Game Stats -->
    <LinearGradientBrush x:Key="HealthGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource GradientHealthStart}" Offset="0"/>
        <GradientStop Color="{StaticResource GradientHealthEnd}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ManaGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource GradientManaStart}" Offset="0"/>
        <GradientStop Color="{StaticResource GradientManaEnd}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ExpGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource GradientExpStart}" Offset="0"/>
        <GradientStop Color="{StaticResource GradientExpEnd}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource GradientAccentStart}" Offset="0"/>
        <GradientStop Color="{StaticResource GradientAccentEnd}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Glow Effect Brush (radial for button glow) -->
    <RadialGradientBrush x:Key="AccentGlowRadialBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5">
        <GradientStop Color="{StaticResource AccentGlow}" Offset="0"/>
        <GradientStop Color="#00FF6500" Offset="1"/>
    </RadialGradientBrush>
    
    <!-- Overlay/Hover Brushes -->
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#33FFFFFF"/>
    
    <Color x:Key="SurfaceOverlay">#18FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceOverlayBrush" Color="{StaticResource SurfaceOverlay}"/>
    
    <Color x:Key="TextGhost">#AAFFFFFF</Color>
    <SolidColorBrush x:Key="TextGhostBrush" Color="{StaticResource TextGhost}"/>
    
    <!-- Legacy Compatibility (maps old DarkX names to new resources) -->
    <Color x:Key="DarkBackground">#FF212121</Color>
    <Color x:Key="DarkBackgroundAlt">#FF141414</Color>
    <Color x:Key="DarkForeground">#FFFFFFFF</Color>
    <Color x:Key="DarkBorder">#FF969696</Color>
    <Color x:Key="DarkAccent1">#FFFF6500</Color>
    <Color x:Key="DarkAccent2">#FFFF0000</Color>
    <Color x:Key="DarkAccent3">#FF00FFFF</Color>
    <Color x:Key="DarkError">#FFFF0000</Color>
    <Color x:Key="TextAccentColor">#FFFF0050</Color>
    <Color x:Key="CheckBoxHoverBorder">#FFFF0050</Color>
    <Color x:Key="PlayerHealthBar">#FF80FF00</Color>
    <Color x:Key="PlayerManaBar">#FF00FFFF</Color>
    <Color x:Key="PlayerExpBar">#FFFF8000</Color>
    
</ResourceDictionary>
