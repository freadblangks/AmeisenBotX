<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <!-- ============================================
         AmeisenBotX Unified Theme - Typography
         ============================================ -->
    
    <!-- Font Families -->
    <FontFamily x:Key="FontPrimary">Bahnschrift Light</FontFamily>
    <FontFamily x:Key="FontMono">Consolas</FontFamily>
    
    <!-- Font Sizes -->
    <sys:Double x:Key="FontSizeXS">9</sys:Double>
    <sys:Double x:Key="FontSizeS">10</sys:Double>
    <sys:Double x:Key="FontSizeBase">12</sys:Double>
    <sys:Double x:Key="FontSizeM">13</sys:Double>
    <sys:Double x:Key="FontSizeL">14</sys:Double>
    <sys:Double x:Key="FontSizeXL">16</sys:Double>
    <sys:Double x:Key="FontSizeXXL">20</sys:Double>
    <sys:Double x:Key="FontSizeHeader">24</sys:Double>
    
    <!-- Font Weights -->
    <FontWeight x:Key="FontWeightLight">Light</FontWeight>
    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>
    
    <!-- ============================================
         TextBlock Styles (prefixed to avoid Color conflicts)
         ============================================ -->
    
    <!-- Header TextBlock - Large titles -->
    <Style x:Key="TextBlockHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeXL}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    
    <!-- Subheader TextBlock - Section headers -->
    <Style x:Key="TextBlockSubheader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    
    <!-- Body TextBlock - Regular content -->
    <Style x:Key="TextBlockBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    
    <!-- Caption TextBlock - Small labels, hints -->
    <Style x:Key="TextBlockCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeS}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>
    
    <!-- Muted TextBlock - Low emphasis -->
    <Style x:Key="TextBlockMuted" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeS}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    </Style>
    
    <!-- Mono TextBlock - Code, technical values -->
    <Style x:Key="TextBlockMono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeM}"/>
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
    </Style>
    
    <!-- Accent TextBlock - Highlighted values -->
    <Style x:Key="TextBlockAccent" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
    </Style>
    
    <!-- Legacy alias for backwards compatibility -->
    <Style x:Key="TextHeader" TargetType="TextBlock" BasedOn="{StaticResource TextBlockHeader}"/>
    
    <!-- ============================================
         Label Styles
         ============================================ -->
    
    <!-- Standard Label -->
    <Style x:Key="LabelBase" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    
    <!-- Header Label -->
    <Style x:Key="LabelHeader" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeXL}"/>
    </Style>
    
    <!-- Caption Label -->
    <Style x:Key="LabelCaption" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeS}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>
    
    <!-- ============================================
         Form Field Styles
         ============================================ -->
    
    <!-- Form Label - For input field labels -->
    <Style x:Key="StandardFormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeS}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    
    <!-- Section Header - For grouping form sections -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Margin" Value="0,12,0,8"/>
    </Style>
    
    <!-- Separator Label - For divider sections -->
    <Style x:Key="SeparatorLabelStyle" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="Padding" Value="0,4"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    
</ResourceDictionary>
