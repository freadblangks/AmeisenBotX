<UserControl x:Class="AmeisenBotX.Views.CharacterCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130" Height="165" Cursor="Hand">
    
    <UserControl.Resources>
        <!-- Hover scale animation -->
        <Storyboard x:Key="HoverIn">
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" 
                             To="1.03" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" 
                             To="1.03" Duration="0:0:0.15"/>
            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="#FFFF6500" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="GlowEffect" Storyboard.TargetProperty="Opacity"
                             To="0.6" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="HoverOut">
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" 
                             To="1.0" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" 
                             To="1.0" Duration="0:0:0.15"/>
            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="#FF404040" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="GlowEffect" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.15"/>
        </Storyboard>
        
        <!-- Context Menu -->
        <ContextMenu x:Key="CardContextMenu" 
                     Background="#FF2A2A2A" BorderBrush="#FF505050" BorderThickness="1">
            <MenuItem x:Name="menuOpenFolder" Header="📁 Open Folder" Click="MenuOpenFolder_Click"/>
            <Separator Background="#FF404040"/>
            <MenuItem x:Name="menuDelete" Header="🗑️ Delete" Click="MenuDelete_Click" Foreground="#FFFF6666"/>
        </ContextMenu>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard Storyboard="{StaticResource HoverIn}"/>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard Storyboard="{StaticResource HoverOut}"/>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Border x:Name="CardBorder" CornerRadius="6" Margin="4" BorderThickness="2" 
            Background="#FF1A1A1A" RenderTransformOrigin="0.5,0.5"
            ContextMenu="{StaticResource CardContextMenu}">
        <Border.BorderBrush>
            <SolidColorBrush x:Name="CardBorderBrush" Color="#FF404040"/>
        </Border.BorderBrush>
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="GlowEffect" Color="#FFFF6500" BlurRadius="12" 
                              ShadowDepth="0" Opacity="0"/>
        </Border.Effect>
        
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Faction indicator (subtle top border) -->
            <Border x:Name="FactionIndicator" Grid.Row="0" Height="3" VerticalAlignment="Top" 
                    Margin="-6,-6,-6,0" CornerRadius="4,4,0,0" Visibility="Collapsed"/>
            
            <!-- Portrait Container -->
            <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Portrait border with accent -->
                <Ellipse x:Name="PortraitBorder" Width="68" Height="68" StrokeThickness="2">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop x:Name="PortraitGradient1" Color="#FFFF6500" Offset="0"/>
                            <GradientStop x:Name="PortraitGradient2" Color="#FFFF3300" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.Fill>
                        <SolidColorBrush Color="#FF2A2A2A"/>
                    </Ellipse.Fill>
                </Ellipse>
                
                <!-- Portrait image (circular clip) -->
                <Ellipse x:Name="PortraitImage" Width="62" Height="62">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="PortraitBrush" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
                
                <!-- Fallback icon (shown when no portrait) -->
                <TextBlock x:Name="FallbackIcon" Text="👤" FontSize="26" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#FF666666" Visibility="Collapsed"/>
                
                <!-- New Config + icon -->
                <Grid x:Name="NewConfigIcon" Visibility="Collapsed">
                    <Ellipse Width="62" Height="62" Fill="#FF2A2A2A"/>
                    <TextBlock Text="➕" FontSize="22" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#FFFF6500"/>
                </Grid>
                
                <!-- Level badge (bottom-right of portrait) -->
                <Border x:Name="LevelBadge" Width="22" Height="22" CornerRadius="11"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,-2,-2" Visibility="Collapsed">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFF6500" Offset="0"/>
                            <GradientStop Color="#FFCC4400" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="LevelText" Text="80" FontSize="10" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
            
            <!-- Character Name / Profile Name -->
            <TextBlock x:Name="ProfileName" Grid.Row="1" 
                       Text="Profile Name" 
                       FontFamily="Bahnschrift" FontSize="13" FontWeight="SemiBold"
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       TextTrimming="CharacterEllipsis"
                       Margin="0,3,0,0"/>
            
            <!-- Stats Line (Class - Zone) -->
            <StackPanel x:Name="StatsPanel" Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,1,0,0">
                <TextBlock x:Name="ClassText" Text="" 
                           FontFamily="Bahnschrift Light" FontSize="10"
                           Foreground="#FF888888"/>
                <TextBlock x:Name="ZoneSeparator" Text=" • " 
                           FontFamily="Bahnschrift Light" FontSize="10"
                           Foreground="#FF666666" Visibility="Collapsed"/>
                <TextBlock x:Name="ZoneText" Text="" 
                           FontFamily="Bahnschrift Light" FontSize="10"
                           Foreground="#FF888888"/>
            </StackPanel>
            
            <!-- Last Played -->
            <TextBlock x:Name="LastPlayedText" Grid.Row="3" 
                       Text="" 
                       FontFamily="Bahnschrift Light" FontSize="9"
                       Foreground="#FF555555" 
                       HorizontalAlignment="Center" 
                       Visibility="Collapsed"
                       Margin="0,2,0,0"/>
        </Grid>
    </Border>
</UserControl>
