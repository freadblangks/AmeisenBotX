<UserControl x:Class="AmeisenBotX.Views.CharacterCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130" Height="165" Cursor="Hand">
    
    <UserControl.Resources>
        <!-- Hover scale animation with Glass Glow -->
        <Storyboard x:Key="HoverIn">
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" 
                             To="1.03" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" 
                             To="1.03" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="{StaticResource Accent}" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="GlowEffect" Storyboard.TargetProperty="Opacity"
                             To="0.8" Duration="0:0:0.15"/>
            <!-- Illuminate background slightly -->
            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                            To="#252525" Duration="0:0:0.15"/>
        </Storyboard>
        
        <Storyboard x:Key="HoverOut">
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" 
                             To="1.0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" 
                             To="1.0" Duration="0:0:0.2"/>
            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="{StaticResource BorderSubtle}" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="GlowEffect" Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.2"/>
            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                            To="#1A1A1A" Duration="0:0:0.2"/>
        </Storyboard>
        
        <!-- Context Menu -->
        <ContextMenu x:Key="CardContextMenu" Style="{DynamicResource ContextMenuStyleDark}">
            <MenuItem x:Name="menuOpenFolder" Header="📁 Open Folder" Click="MenuOpenFolder_Click"/>
            <Separator Style="{DynamicResource SeparatorStyleDark}"/>
            <MenuItem x:Name="menuDelete" Header="🗑️ Delete" Click="MenuDelete_Click" 
                      Foreground="{DynamicResource ErrorBrush}"/>
        </ContextMenu>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard Storyboard="{StaticResource HoverIn}"/>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard Storyboard="{StaticResource HoverOut}"/>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Border x:Name="CardBorder" CornerRadius="8" Margin="6" BorderThickness="1" 
            RenderTransformOrigin="0.5,0.5"
            ContextMenu="{StaticResource CardContextMenu}">
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource Surface}"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="{DynamicResource BorderSubtle}"/>
        </Border.BorderBrush>
        <Border.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="GlowEffect" Color="{DynamicResource Accent}" BlurRadius="16" 
                              ShadowDepth="0" Opacity="0"/>
        </Border.Effect>
        
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            
            <!-- Watermark (Background) -->
            <TextBlock x:Name="ProfileWatermark" Grid.RowSpan="4"
                       Text="PROFILE"
                       FontSize="11" FontFamily="Bahnschrift SemiBold" FontWeight="Regular"
                       Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.15"
                       VerticalAlignment="Top" HorizontalAlignment="Left"
                       Margin="1,1,0,0" IsHitTestVisible="False"/>

            <!-- Faction indicator (subtle top border) -->
            <!-- Faction "Spotlight" Gradient (Bottom Glow) -->
            <!-- Faction "Spotlight" Gradient (Bottom Glow) -->
            <Rectangle x:Name="FactionSpotlight" Grid.RowSpan="4" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                       Width="80" Height="40" Margin="0" RadiusX="20" RadiusY="20" 
                       Visibility="Collapsed" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <RadialGradientBrush GradientOrigin="0.5,1" Center="0.5,1" RadiusX="0.5" RadiusY="0.9">
                        <GradientStop x:Name="FactionSpotlightStart" Color="{DynamicResource Accent}" Offset="0"/>
                        <GradientStop x:Name="FactionSpotlightEnd" Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            
            <!-- Portrait Container -->
            <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,0">
                <!-- Portrait border with accent -->
                <Ellipse x:Name="PortraitBorder" Width="68" Height="68" StrokeThickness="2">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop x:Name="PortraitGradient1" Color="{DynamicResource Accent}" Offset="0"/>
                            <GradientStop x:Name="PortraitGradient2" Color="{DynamicResource AccentHover}" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{StaticResource BackgroundElevated}"/>
                    </Ellipse.Fill>
                </Ellipse>
                
                <!-- Portrait image (circular clip) -->
                <Ellipse x:Name="PortraitImage" Width="62" Height="62">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="PortraitBrush" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
                
                <!-- Fallback icon (shown when no portrait) -->
                <TextBlock x:Name="FallbackIcon" Text="👤" FontSize="26" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" Visibility="Collapsed"/>
                
                <!-- New Config + icon -->
                <Grid x:Name="NewConfigIcon" Visibility="Collapsed">
                    <Ellipse Width="62" Height="62" Fill="{DynamicResource BackgroundElevatedBrush}"/>
                    <TextBlock Text="➕" FontSize="22" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}"/>
                </Grid>
                
                <!-- Level badge (Blizzlike style) -->
                <Border x:Name="LevelBadge" Width="24" Height="24" CornerRadius="12"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        BorderThickness="1"
                        Margin="0,0,-4,-4" Visibility="Collapsed">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFFD700" Offset="0"/>
                            <GradientStop Color="#FFAFAB00" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Background>
                        <SolidColorBrush Color="#E6000000"/>
                    </Border.Background>
                    <TextBlock x:Name="LevelText" Text="80" FontSize="11" FontWeight="Bold"
                               Foreground="#FFFFD700" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0"/>
                </Border>
            </Grid>
            
            <!-- Character Name / Profile Name -->
            <TextBlock x:Name="ProfileName" Grid.Row="1" 
                       Text="Profile Name" 
                       FontFamily="Bahnschrift SemiBold" FontSize="15" 
                       Foreground="{DynamicResource TextPrimaryBrush}" 
                       HorizontalAlignment="Center" 
                       TextTrimming="CharacterEllipsis"
                       Margin="0,4,0,0"/>
            
            <!-- Stats Line (Class - Zone) -->
            <StackPanel x:Name="StatsPanel" Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,2,0,0">
                <TextBlock x:Name="ClassText" Text="" 
                           FontFamily="Bahnschrift" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="ZoneSeparator" Text=" • " 
                           FontFamily="Bahnschrift" FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" Visibility="Collapsed"/>
                <TextBlock x:Name="ZoneText" Text="" 
                           FontFamily="Bahnschrift" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            
            <!-- Last Played -->
            <TextBlock x:Name="LastPlayedText" Grid.Row="3" 
                       Text="" 
                       FontFamily="Bahnschrift Light" FontSize="11"
                       Foreground="#BBBBBB" 
                       HorizontalAlignment="Center" 
                       Visibility="Collapsed"
                       Margin="0,2,0,0"/>
        </Grid>
    </Border>
</UserControl>
