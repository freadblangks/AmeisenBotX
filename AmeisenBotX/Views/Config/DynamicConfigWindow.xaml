<Window x:Class="AmeisenBotX.Views.Config.DynamicConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AmeisenBotX.ViewModels.Config"
        mc:Ignorable="d"
        Title="AmeisenBotX Configuration" Height="600" Width="400" MinWidth="400"
        WindowStyle="None" AllowsTransparency="True" BorderThickness="1" ResizeMode="CanResizeWithGrip" 
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        FontFamily="Bahnschrift Light" FontSize="14">
    
    <Window.BorderBrush>
        <SolidColorBrush Color="{DynamicResource DarkAccent1}" />
    </Window.BorderBrush>
    
    <Window.Background>
        <SolidColorBrush Color="{DynamicResource DarkBackground}" />
    </Window.Background>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Local Brushes Mapped -->
        <SolidColorBrush x:Key="DarkForegroundBrush" Color="{DynamicResource DarkForeground}" />
        <SolidColorBrush x:Key="DarkBackgroundBrush" Color="{DynamicResource DarkBackground}" />
        <SolidColorBrush x:Key="DarkBorderBrush" Color="{DynamicResource DarkBorder}" />
        <SolidColorBrush x:Key="DarkAccent1Brush" Color="{DynamicResource DarkAccent1}" />
        <SolidColorBrush x:Key="RowHoverBrush" Color="#1FFFFFFF" />

        <!-- Expander Toggle Button Template -->
        <ControlTemplate x:Key="ExpanderToggleButton" TargetType="{x:Type ToggleButton}">
            <Border Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path x:Name="arrow" Data="M 1,1.5 L 4.5,5 L 8,1.5" HorizontalAlignment="Center" VerticalAlignment="Center" 
                          Stroke="{StaticResource DarkAccent1Brush}" StrokeThickness="2" Margin="10,0,0,0" RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </Path.RenderTransform>
                    </Path>
                    <ContentPresenter Grid.Column="1" Margin="10,5,0,5" HorizontalAlignment="Left" VerticalAlignment="Center"
                                      TextBlock.Foreground="White" TextBlock.FontWeight="Bold"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="arrow" Property="RenderTransform">
                        <Setter.Value>
                            <RotateTransform Angle="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Custom Expander Style -->
        <Style x:Key="ModernExpanderStyle" TargetType="{x:Type Expander}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <Border BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Name="ContentRow" Height="0"/>
                                </Grid.RowDefinitions>
                                
                                <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Template="{StaticResource ExpanderToggleButton}"
                                              Content="{TemplateBinding Header}"
                                              Background="#FF2A2A2A" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="0,1,0,1"/>
                                
                                <Border Name="ContentSite" Grid.Row="1" Background="{StaticResource DarkBackgroundBrush}" Padding="10,5">
                                    <ContentPresenter />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentRow" Property="Height" Value="Auto" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Common Style for Property Rows (Hover Effect) -->
        <Style x:Key="PropertyRowBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,-1,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Template for Boolean Properties -->
        <DataTemplate DataType="{x:Type vm:BoolConfigProperty}">
            <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                   <CheckBox IsChecked="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                          Content="{Binding Name}" 
                          Style="{DynamicResource CheckBoxStyleDark}" 
                          Foreground="{StaticResource DarkForegroundBrush}"
                          Margin="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/> 
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for String Properties -->
        <DataTemplate DataType="{x:Type vm:StringConfigProperty}">
             <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding Name}" Foreground="{StaticResource DarkForegroundBrush}" Padding="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource TextBoxStyleDark}"
                             Foreground="{StaticResource DarkForegroundBrush}"
                             BorderBrush="{StaticResource DarkBorderBrush}"
                             Background="{StaticResource DarkBackgroundBrush}"
                             FontFamily="Bahnschrift Light" Height="24" VerticalContentAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for Integer Properties -->
        <DataTemplate DataType="{x:Type vm:IntConfigProperty}">
            <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding Name}" Foreground="{StaticResource DarkForegroundBrush}" Padding="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/>
                    
                    <!-- Standard Text Input -->
                    <TextBox x:Name="valBox" Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource TextBoxStyleDark}"
                             Foreground="{StaticResource DarkForegroundBrush}"
                             BorderBrush="{StaticResource DarkBorderBrush}" 
                             Background="{StaticResource DarkBackgroundBrush}"
                             FontFamily="Bahnschrift Light" Height="24" VerticalContentAlignment="Center"/>

                    <!-- Slider Input -->
                    <Grid x:Name="sliderGrid" Grid.Column="1" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider Value="{Binding Value}" Minimum="{Binding Minimum}" Maximum="{Binding Maximum}" 
                                Style="{DynamicResource SliderStyleDark}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="5,0,0,0"
                                 Style="{DynamicResource TextBoxStyleDark}"
                                 Foreground="{StaticResource DarkForegroundBrush}"
                                 BorderBrush="{StaticResource DarkBorderBrush}" 
                                 Background="{StaticResource DarkBackgroundBrush}"
                                 FontFamily="Bahnschrift Light" Height="24" VerticalContentAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
             <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding UseSlider}" Value="True">
                    <Setter TargetName="valBox" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="sliderGrid" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Template for Floating Point Properties -->
         <DataTemplate DataType="{x:Type vm:FloatConfigProperty}">
             <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding Name}" Foreground="{StaticResource DarkForegroundBrush}" Padding="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/>
                    
                    <TextBox x:Name="valBox" Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource TextBoxStyleDark}"
                             Foreground="{StaticResource DarkForegroundBrush}"
                             BorderBrush="{StaticResource DarkBorderBrush}" 
                             Background="{StaticResource DarkBackgroundBrush}"
                             FontFamily="Bahnschrift Light" Height="24" VerticalContentAlignment="Center"/>

                    <Grid x:Name="sliderGrid" Grid.Column="1" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider Value="{Binding Value}" Minimum="{Binding Minimum}" Maximum="{Binding Maximum}" 
                                Style="{DynamicResource SliderStyleDark}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="5,0,0,0"
                                 Style="{DynamicResource TextBoxStyleDark}"
                                 Foreground="{StaticResource DarkForegroundBrush}"
                                 BorderBrush="{StaticResource DarkBorderBrush}" 
                                 Background="{StaticResource DarkBackgroundBrush}"
                                 FontFamily="Bahnschrift Light" Height="24" VerticalContentAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
             <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding UseSlider}" Value="True">
                    <Setter TargetName="valBox" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="sliderGrid" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
         </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:DoubleConfigProperty}">
             <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding Name}" Foreground="{StaticResource DarkForegroundBrush}" Padding="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/>
                    
                    <TextBox x:Name="valBox" Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource TextBoxStyleDark}"
                             Foreground="{StaticResource DarkForegroundBrush}"
                             BorderBrush="{StaticResource DarkBorderBrush}" 
                             Background="{StaticResource DarkBackgroundBrush}"
                             FontFamily="Bahnschrift Light" Height="24" VerticalContentAlignment="Center"/>

                    <Grid x:Name="sliderGrid" Grid.Column="1" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider Value="{Binding Value}" Minimum="{Binding Minimum}" Maximum="{Binding Maximum}" 
                                Style="{DynamicResource SliderStyleDark}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="5,0,0,0"
                                 Style="{DynamicResource TextBoxStyleDark}"
                                 Foreground="{StaticResource DarkForegroundBrush}"
                                 BorderBrush="{StaticResource DarkBorderBrush}" 
                                 Background="{StaticResource DarkBackgroundBrush}"
                                 FontFamily="Bahnschrift Light" Height="24" VerticalContentAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
             <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding UseSlider}" Value="True">
                    <Setter TargetName="valBox" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="sliderGrid" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
         </DataTemplate>

        <!-- Template for Enum Properties -->
        <DataTemplate DataType="{x:Type vm:EnumConfigProperty}">
            <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding Name}" Foreground="{StaticResource DarkForegroundBrush}" Padding="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Options}" SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource ComboBoxStyleDark}"
                              Foreground="{StaticResource DarkForegroundBrush}"
                              BorderBrush="{StaticResource DarkBorderBrush}"
                              Background="{StaticResource DarkBackgroundBrush}"
                              FontFamily="Bahnschrift Light" Height="24"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for File Path Properties -->
        <DataTemplate DataType="{x:Type vm:FileConfigProperty}">
            <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding Name}" Foreground="{StaticResource DarkForegroundBrush}" Padding="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource TextBoxStyleDark}"
                             Foreground="{StaticResource DarkForegroundBrush}"
                             BorderBrush="{StaticResource DarkBorderBrush}"
                             Background="{StaticResource DarkBackgroundBrush}"
                             VerticalAlignment="Center" Height="24" VerticalContentAlignment="Center" FontFamily="Bahnschrift Light"/>
                    <Button Grid.Column="2" Command="{Binding BrowseCommand}" Content="..." Width="28" Margin="5,0,0,0" Height="24"
                            Style="{DynamicResource ButtonStyleDark}"
                            Foreground="{StaticResource DarkForegroundBrush}"
                            BorderBrush="{StaticResource DarkBorderBrush}"
                            Background="{StaticResource DarkBackgroundBrush}"
                            FontFamily="Verdana"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for Selection Properties (ComboBox) -->
        <DataTemplate DataType="{x:Type vm:SelectionConfigProperty}">
           <Border Style="{StaticResource PropertyRowBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{Binding Name}" Foreground="{StaticResource DarkForegroundBrush}" Padding="0" FontFamily="Bahnschrift Light" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Options}" SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource ComboBoxStyleDark}"
                              Foreground="{StaticResource DarkForegroundBrush}"
                              BorderBrush="{StaticResource DarkBorderBrush}"
                              Background="{StaticResource DarkBackgroundBrush}"
                              FontFamily="Bahnschrift Light" Height="24"/>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Search -->
            <RowDefinition Height="*"/>    <!-- Settings Body -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- HEADER (Matching MainWindow Title Bar) -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Rectangle Height="28" VerticalAlignment="Top" Fill="#00000000" IsHitTestVisible="False"/> <!-- Drag Handle Area -->
            
            <Label Content="Configuration" HorizontalAlignment="Left" VerticalAlignment="Top" 
                   FontSize="16" Margin="5,0,0,0" FontFamily="Bahnschrift Light" Foreground="{StaticResource DarkForegroundBrush}"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Height="28">
                <Button Content="💾" Click="ButtonSave_Click" 
                        Width="28" Height="27"
                        Style="{DynamicResource ButtonStyleDark}" 
                        Foreground="{StaticResource DarkForegroundBrush}"
                        FontFamily="Segoe UI Emoji" FontSize="14"
                        BorderThickness="1,0,0,1" Margin="0,0,-1,0" 
                        ToolTip="Save &amp; Close"/>
                <Button Content="X" Click="ButtonClose_Click" 
                        Width="28" Height="27"
                        Style="{DynamicResource ButtonStyleDark}" 
                        Foreground="{StaticResource DarkForegroundBrush}"
                        FontFamily="Verdana" FontSize="14"
                        BorderThickness="1,0,0,1" />
            </StackPanel>

             <Rectangle VerticalAlignment="Top" Height="1" Fill="{StaticResource DarkBorderBrush}" Margin="0,27,0,0"/>
        </Grid>

        <!-- SEARCH BAR -->
        <Border Grid.Row="1" Margin="10,0,10,10" Padding="0,0,0,5">
            <Grid>
                <Label Content="🔍" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="{StaticResource DarkForegroundBrush}" Margin="5,0,0,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="30,0,0,0"
                         Height="25" VerticalContentAlignment="Center"
                         Style="{DynamicResource TextBoxStyleDark}"
                         Foreground="{StaticResource DarkForegroundBrush}"
                         BorderBrush="{StaticResource DarkBorderBrush}" 
                         Background="{StaticResource DarkBackgroundBrush}"
                         Tag="Search settings..."
                         FontFamily="Bahnschrift Light"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="2" Margin="5,0,5,5" BorderThickness="0">
            <ItemsControl ItemsSource="{Binding PropertiesView}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <Expander Style="{StaticResource ModernExpanderStyle}" IsExpanded="True" Header="{Binding Name}" Margin="0,5,0,5">
                                                <ItemsPresenter />
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
