<Window x:Class="AmeisenBotX.Windows.AiDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:themes="clr-namespace:AmeisenBotX.Themes"
        mc:Ignorable="d" 
        Title="AmeisenBotX - AI Debugger" Height="800" Width="450"
        Icon="/icon.png"
        Style="{DynamicResource StandardWindowStyle}"
        themes:WindowAssist.Icon="🧠">

    <themes:WindowAssist.HeaderContent>
        <Button x:Name="buttonExit" Click="ButtonExit_Click" 
                Style="{DynamicResource StandardExitButtonStyle}"/>
    </themes:WindowAssist.HeaderContent>

    <Window.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header / Status -->
            <Border Grid.Row="0" Background="{DynamicResource BackgroundAltBrush}" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Strategy: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="StrategyText" Text="Unknown" Foreground="{DynamicResource AccentBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>

                    <TextBlock Text="Win Probability: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16"/>
                    <TextBlock x:Name="WinProbText" Text="0%" Foreground="LimeGreen" FontSize="16" Margin="0,0,20,0"/>

                    <TextBlock Text="Status: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16"/>
                    <TextBlock x:Name="StatusText" Text="Waiting..." Foreground="{DynamicResource TextMutedBrush}" FontSize="16"/>
                </StackPanel>
            </Border>

            <!-- Neural Net Canvas -->
            <Canvas x:Name="BrainCanvas" Grid.Row="1" Background="{DynamicResource BackgroundBrush}" ClipToBounds="True"/>

            <!-- Tooltip Overlay -->
            <Popup x:Name="InfoPopup" Placement="Mouse" IsOpen="False">
                <Border Background="{DynamicResource BackgroundAltBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="4" Padding="5">
                    <TextBlock x:Name="PopupText" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
            </Popup>
        </Grid>
    </Window.Content>
</Window>
