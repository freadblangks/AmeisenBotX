<Window x:Class="AmeisenBotX.Windows.AutopilotDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:themes="clr-namespace:AmeisenBotX.Themes"
        mc:Ignorable="d"
        Title="Autopilot Debugger" Height="450" Width="800"
        Style="{DynamicResource StandardWindowStyle}"
        themes:WindowAssist.Icon="🤖"
        Loaded="Window_Loaded" Unloaded="Window_Unloaded">

    <themes:WindowAssist.HeaderContent>
        <StackPanel Orientation="Horizontal">
            <Button x:Name="buttonRefresh" Content="↻" Click="ButtonRefresh_Click" 
                    Style="{DynamicResource StandardToolbarButtonStyle}"
                    ToolTip="Force Quest Update"/>
            <Button x:Name="buttonExit" Click="ButtonExit_Click" 
                    Style="{DynamicResource StandardExitButtonStyle}"/>
        </StackPanel>
    </themes:WindowAssist.HeaderContent>

    <Window.Content>
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Status & Progression -->
            <Border Grid.Column="0" Background="{DynamicResource BackgroundAltBrush}" CornerRadius="4" Margin="0,0,5,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Autopilot Status" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Current Task:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="txtCurrentTask" Text="Initializing..." FontSize="14" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Mode:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="txtMode" Text="-" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>
                    
                    <TextBlock Text="Progression" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Level: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtLevel" Text="0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="XP: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ProgressBar Grid.Row="1" Grid.Column="1" x:Name="barXp" Height="12" Margin="5,2,0,0"/>
                    </Grid>
                    <TextBlock x:Name="txtXpText" Text="0 / 0 (0%)" FontSize="10" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}"/>

                </StackPanel>
            </Border>

            <!-- Right Column: Quests & POIs -->
            <Border Grid.Column="1" Background="{DynamicResource BackgroundAltBrush}" CornerRadius="4" Margin="5,0,0,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Active Objectives" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Objectives Section -->
                            <ItemsControl x:Name="listObjectives">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="3" Margin="0,0,0,5" Padding="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="❌" Style="{DynamicResource StandardToolbarButtonStyle}" 
                                                                Click="ButtonAbandon_Click" 
                                                                ToolTip="Abandon Quest" 
                                                                Width="18" Height="18" Margin="0,0,5,0" Padding="0"/>
                                                        <TextBlock Text="{Binding QuestTitle}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding TargetName}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding OriginalText}" FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                    
                                                    <!-- Rewards Sub-list -->
                                                    <ItemsControl ItemsSource="{Binding Rewards}" Margin="10,5,0,0">
                                                         <ItemsControl.ItemTemplate>
                                                             <DataTemplate>
                                                                 <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                     <TextBlock Text="🎁" Margin="0,0,5,0"/>
                                                                     <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,5,0"/>
                                                                     <TextBlock Text="{Binding Score, StringFormat='({0:F1})'}" Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                                                                 </StackPanel>
                                                             </DataTemplate>
                                                         </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding LocationText}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Window.Content>
</Window>
