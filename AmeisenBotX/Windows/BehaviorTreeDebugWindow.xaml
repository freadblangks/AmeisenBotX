<Window x:Class="AmeisenBotX.Windows.BehaviorTreeDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:themes="clr-namespace:AmeisenBotX.Themes"
        mc:Ignorable="d" 
        Title="AmeisenBotX - Behavior Tree Debugger" Height="600" Width="1000"
        Icon="/icon.png"
        Style="{DynamicResource StandardWindowStyle}"
        themes:WindowAssist.Icon="🌳">

    <themes:WindowAssist.HeaderContent>
        <StackPanel Orientation="Horizontal">
            <Button x:Name="ButtonClear" Content="🗑️" Click="ButtonClear_Click" 
                    Style="{DynamicResource StandardToolbarButtonStyle}"
                    ToolTip="Clear history"/>
            <Button x:Name="ButtonPause" Content="⏸️" Click="ButtonPause_Click" 
                    Style="{DynamicResource StandardToolbarButtonStyle}"
                    ToolTip="Pause updates"/>
            <Button x:Name="buttonExit" Click="ButtonExit_Click" 
                    Style="{DynamicResource StandardExitButtonStyle}"/>
        </StackPanel>
    </themes:WindowAssist.HeaderContent>

    <Window.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BackgroundAltBrush}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Status Row -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Mode: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="Bold"/>
                        <TextBlock x:Name="ModeText" Text="Autopilot" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                        <TextBlock Text="Status: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                        <TextBlock x:Name="StatusText" Text="Idle" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
                    </StackPanel>
                    
                    <!-- Current Goal (large, prominent) -->
                    <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12,8" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="🎯 CURRENT GOAL" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="CurrentGoalText" Text="Waiting..." Foreground="{DynamicResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                            <TextBlock x:Name="CurrentGoalSubText" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Current Execution Path -->
            <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1">
                <StackPanel>
                    <TextBlock Text="📍 Recent Execution:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ExecutionPathText" Text="⏳ Waiting..." Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Tree Nodes List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="TreePanel" Margin="5"/>
            </ScrollViewer>
        </Grid>
    </Window.Content>
</Window>
