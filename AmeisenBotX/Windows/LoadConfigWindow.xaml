<Window x:Class="AmeisenBotX.Windows.LoadConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:themes="clr-namespace:AmeisenBotX.Themes"
        mc:Ignorable="d"
        Title="AmeisenBotX" Height="520" Width="680" MinHeight="400" MinWidth="520"
        Loaded="Window_Loaded" 
        Icon="/icon.png" ResizeMode="CanResizeWithGrip"
        Style="{DynamicResource StandardWindowStyle}"
        themes:WindowAssist.Icon="🤖">

    <Window.Resources>
        <!-- Realm group header style (local, uses global resources) -->
        <Style x:Key="RealmHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift Light"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="12,12,12,6"/>
        </Style>
    </Window.Resources>

    <themes:WindowAssist.HeaderContent>
        <Button x:Name="buttonClose" Click="ButtonClose_Click" 
                Style="{DynamicResource StandardExitButtonStyle}"/>
    </themes:WindowAssist.HeaderContent>
    
    <Window.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="24,24,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="Select Character" FontFamily="Bahnschrift SemiBold" FontSize="24"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="ProfileCountText" Text="0 profiles" 
                               FontSize="13" Margin="0,4,0,0" 
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                
                <!-- Modern Search Box -->
                <Grid Grid.Column="1" Width="240" VerticalAlignment="Center">
                    <Border Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="14" 
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="🔍" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBox x:Name="SearchBox" Padding="30,6,12,6" Height="28"
                                     TextChanged="SearchBox_TextChanged"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource AccentBrush}"
                                     FontFamily="Bahnschrift"/>
                            <TextBlock x:Name="SearchPlaceholder" Text="Search..." IsHitTestVisible="False"
                                       FontSize="13" Foreground="{DynamicResource TextMutedBrush}" 
                                       Margin="32,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            
            <!-- Separator -->
            <Rectangle Grid.Row="1" Height="1" Margin="16,0" Fill="{DynamicResource BorderBrush}"/>
            
            <!-- Grouped Character Grid -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled" Margin="0,8">
                <StackPanel x:Name="GroupedContainer"/>
            </ScrollViewer>
            
            <!-- Empty State -->
            <StackPanel x:Name="EmptyState" Grid.Row="2" 
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="No bot profiles yet" FontSize="24" 
                           HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="Click the + card to create your first bot" 
                           FontSize="14" 
                           HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" 
                           Margin="0,4,0,0"/>
            </StackPanel>
            
            <!-- No Search Results State -->
            <StackPanel x:Name="NoResultsState" Grid.Row="2" 
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="No matching profiles" FontSize="18" 
                           HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Window.Content>
</Window>
