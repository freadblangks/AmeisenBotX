<Window x:Class="AmeisenBotX.Windows.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:themes="clr-namespace:AmeisenBotX.Themes"
        mc:Ignorable="d"
        Title="AmeisenBotX - Map" Height="600" Width="800" MinHeight="316" MinWidth="400" 
        Icon="/icon.png" 
        Loaded="Window_Loaded" Unloaded="Window_Unloaded" 
        IsVisibleChanged="Window_IsVisibleChanged" SizeChanged="Window_SizeChanged"
        Style="{DynamicResource StandardWindowStyle}"
        themes:WindowAssist.Icon="🗺️">

    <themes:WindowAssist.HeaderContent>
        <StackPanel Orientation="Horizontal">
            <!-- Zoom Slider in Title Bar -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Slider x:Name="sliderZoom" Width="120" VerticalAlignment="Center" 
                        Maximum="5" Minimum="0.75" SmallChange="1" ValueChanged="SliderZoom_ValueChanged"/>
            </StackPanel>

            <Button x:Name="buttonExit" Click="ButtonExit_Click" 
                    Style="{DynamicResource StandardExitButtonStyle}"/>
        </StackPanel>
    </themes:WindowAssist.HeaderContent>

    <!-- Main Content -->
    <Window.Content>
        <Grid>
            <!-- Map Canvas -->
            <Rectangle x:Name="mapCanvasBackground" Fill="{DynamicResource BackgroundAltBrush}"/>
            <Image x:Name="mapCanvas" Stretch="Fill"/> 
            
            <!-- Side Panel (Overlay) -->
            <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="0">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <Grid x:Name="gridSidemenu" Margin="0,0,14,0" Width="146">
                         <!-- Players Section -->
                         <CheckBox x:Name="checkboxRenderPlayers" Content="Render Players" 
                                   Margin="3,4,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderPlayers_Checked" Unchecked="CheckboxRenderPlayers_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderPlayerNames" Content="Names" 
                                   Margin="19,24,0,0" VerticalAlignment="Top" Width="127" 
                                   Checked="CheckboxRenderPlayerNames_Checked" Unchecked="CheckboxRenderPlayerNames_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderPlayerInfo" Content="Info" 
                                   Margin="19,44,0,0" VerticalAlignment="Top" Width="127" 
                                   Checked="CheckboxRenderPlayerInfo_Checked" Unchecked="CheckboxRenderPlayerInfo_Unchecked"/>
                         
                         <!-- Units Section -->
                         <CheckBox x:Name="checkboxRenderUnits" Content="Render Units" 
                                   Margin="3,72,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderUnits_Checked" Unchecked="CheckboxRenderUnits_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderUnitNames" Content="Names" 
                                   Margin="19,92,0,0" VerticalAlignment="Top" Width="127" 
                                   Checked="CheckboxRenderUnitNames_Checked" Unchecked="CheckboxRenderUnitNames_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderUnitInfo" Content="Info" 
                                   Margin="19,112,0,0" VerticalAlignment="Top" Width="127" 
                                   Checked="CheckboxRenderUnitInfo_Checked" Unchecked="CheckboxRenderUnitInfo_Unchecked"/>
                         
                         <!-- Resources Section -->
                         <CheckBox x:Name="checkboxRenderOres" Content="Ores" 
                                   Margin="3,140,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderOres_Checked" Unchecked="CheckboxRenderOres_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderHerbs" Content="Herbs" 
                                   Margin="3,160,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderHerbs_Checked" Unchecked="CheckboxRenderHerbs_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderQuestPois" Content="Quest POIs" 
                                   Margin="3,180,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderQuestPois_Checked" Unchecked="CheckboxRenderQuestPois_Unchecked"/>
                         
                         <!-- Other Section -->
                         <CheckBox x:Name="checkboxRenderMe" Content="Me" 
                                   Margin="3,208,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderMe_Checked" Unchecked="CheckboxRenderMe_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderCurrentPath" Content="Current Path" 
                                   Margin="3,228,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderCurrentPath_Checked" Unchecked="CheckboxRenderCurrentPath_Unchecked"/>
                         <CheckBox x:Name="checkboxRenderDungeonPath" Content="Dungeon Path" 
                                   Margin="3,248,0,0" VerticalAlignment="Top" Width="143" 
                                   Checked="CheckboxRenderDungeonPath_Checked" Unchecked="CheckboxRenderDungeonPath_Unchecked"/>
                    </Grid>
                    
                    <Button x:Name="buttonSidebar" Content="||" BorderThickness="0,1,1,1" Padding="1,1,2,5" 
                            Style="{DynamicResource SecondaryButtonStyle}"
                            HorizontalAlignment="Right" Width="20" VerticalAlignment="Stretch" 
                            FontSize="10" Click="ButtonSidebar_Click"/>
                            
                    <!-- Border Lines -->
                    <Rectangle HorizontalAlignment="Stretch" Height="1" VerticalAlignment="Bottom" 
                               Stroke="{DynamicResource BorderBrush}"/>
                    <Rectangle Height="1" VerticalAlignment="Top" 
                               Stroke="{DynamicResource BorderBrush}"/>
                    <Rectangle Width="1" HorizontalAlignment="Right" VerticalAlignment="Stretch" 
                               Fill="{DynamicResource BorderBrush}"/>
                </Grid>
            </WrapPanel>
        </Grid>
    </Window.Content>
</Window>